{
  "name": "enrollment-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm:server:start\" \"npm:client\"",
    "dev": "concurrently \"npm:server:dev\" \"npm:client\"",
    "server:start": "npm start --prefix server",
    "server:dev": "npm run dev --prefix server",
    "client": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.9.1",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0"
  },
  "allowScripts": {
    "core-js@3.49.0": true
  }
}
